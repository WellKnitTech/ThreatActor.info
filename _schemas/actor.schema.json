{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threatactor.info/schemas/actor.schema.json",
  "title": "ThreatActor.info actor record",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "aliases", "description", "url"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "pattern": "^/[a-z0-9][a-z0-9-]*$"
    },
    "country": {
      "type": "string",
      "minLength": 2
    },
    "sector_focus": {
      "$ref": "#/$defs/stringArray"
    },
    "targeted_victims": {
      "$ref": "#/$defs/stringArray"
    },
    "incident_type": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/stringArray"
        }
      ]
    },
    "first_seen": {
      "$ref": "#/$defs/year"
    },
    "last_activity": {
      "$ref": "#/$defs/year"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "risk_level": {
      "type": "string",
      "enum": ["Critical", "High", "Medium", "Low"]
    },
    "external_id": {
      "type": "string",
      "minLength": 1
    },
    "external_url": {
      "$ref": "#/$defs/httpUrl"
    },
    "mitre_id": {
      "type": "string",
      "pattern": "^G\\d{4}$"
    },
    "mitre_url": {
      "$ref": "#/$defs/httpUrl"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "source_name": {
      "type": "string",
      "minLength": 1
    },
    "source_attribution": {
      "type": "string",
      "minLength": 1
    },
    "source_record_url": {
      "$ref": "#/$defs/httpUrl"
    },
    "source_license": {
      "type": "string",
      "minLength": 1
    },
    "source_license_url": {
      "$ref": "#/$defs/httpUrl"
    },
    "operations": {
      "$ref": "#/$defs/stringArray"
    },
    "malware": {
      "$ref": "#/$defs/stringArray"
    },
    "ttps": {
      "$ref": "#/$defs/stringArray"
    },
    "cisa_kev_cves": {
      "$ref": "#/$defs/stringArray"
    },
    "urls": {
      "$ref": "#/$defs/stringArray"
    },
    "domains": {
      "$ref": "#/$defs/stringArray"
    },
    "ips": {
      "$ref": "#/$defs/stringArray"
    },
    "hashes": {
      "$ref": "#/$defs/stringArray"
    },
    "campaigns": {
      "$ref": "#/$defs/stringArray"
    },
    "provenance": {
      "type": "object"
    },
    "analyst_notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "year": {
      "type": "string",
      "pattern": "^\\d{4}$"
    },
    "httpUrl": {
      "type": "string",
      "pattern": "^https?://"
    }
  }
}
