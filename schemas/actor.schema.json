{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threatactor.info/schemas/actor.schema.json",
  "title": "Threat actor metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "aliases", "description", "url"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "description": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "pattern": "^/[a-z0-9][a-z0-9-]*$" },
    "country": { "type": "string", "minLength": 2 },
    "sector_focus": { "$ref": "#/$defs/stringArray" },
    "targeted_victims": { "$ref": "#/$defs/stringArray" },
    "first_seen": { "type": "string", "pattern": "^[0-9]{4}$" },
    "last_activity": { "type": "string", "pattern": "^[0-9]{4}$" },
    "last_updated": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "risk_level": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
    "source": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "source_attribution": { "type": "string", "minLength": 1 },
    "source_record_url": { "type": "string", "minLength": 1 },
    "source_license": { "type": "string", "minLength": 1 },
    "source_license_url": { "type": "string", "minLength": 1 },
    "provenance": { "type": "object" },
    "external_id": { "type": "string", "minLength": 1 },
    "external_url": { "type": "string", "minLength": 1 },
    "mitre_id": { "type": "string", "minLength": 1 },
    "mitre_url": { "type": "string", "minLength": 1 },
    "incident_type": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/stringArray" }
      ]
    },
    "operations": { "$ref": "#/$defs/stringArray" },
    "malware": { "$ref": "#/$defs/stringArray" },
    "cisa_kev_cves": { "$ref": "#/$defs/stringArray" },
    "domains": { "$ref": "#/$defs/stringArray" },
    "urls": { "$ref": "#/$defs/stringArray" },
    "hashes": { "$ref": "#/$defs/stringArray" },
    "ttps": { "$ref": "#/$defs/stringArray" },
    "analyst_notes": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
