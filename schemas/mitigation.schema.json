{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threatactor.info/schemas/mitigation.schema.json",
  "title": "Generated MITRE mitigation page (front matter subset)",
  "type": "object",
  "required": ["layout", "title", "mitre_id", "permalink"],
  "properties": {
    "layout": { "const": "mitigation" },
    "title": { "type": "string" },
    "mitre_id": { "type": "string", "pattern": "^M\\d{4}$" },
    "permalink": { "type": "string" },
    "mitre_url": { "type": "string" },
    "domains": { "type": "array", "items": { "type": "string" } }
  }
}
