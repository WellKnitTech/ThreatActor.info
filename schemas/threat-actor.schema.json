{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threatactor.info/schemas/threat-actor.schema.json",
  "title": "ThreatActor.info source actor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "aliases",
    "description",
    "url"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "pattern": "^/[a-z0-9][a-z0-9-]*$"
    },
    "country": {
      "type": "string",
      "minLength": 2
    },
    "sector_focus": {
      "$ref": "#/$defs/stringArray"
    },
    "targeted_victims": {
      "$ref": "#/$defs/stringArray"
    },
    "incident_type": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/stringArray"
        }
      ]
    },
    "first_seen": {
      "type": "string",
      "pattern": "^(19|20)\\d{2}$"
    },
    "last_activity": {
      "type": "string",
      "pattern": "^(19|20)\\d{2}$"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "Critical",
        "High",
        "Medium",
        "Low"
      ]
    },
    "external_id": {
      "type": "string",
      "minLength": 1
    },
    "external_url": {
      "type": "string",
      "format": "uri"
    },
    "mitre_id": {
      "type": "string",
      "pattern": "^G\\d{4}$"
    },
    "mitre_url": {
      "type": "string",
      "format": "uri"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "source_name": {
      "type": "string",
      "minLength": 1
    },
    "source_attribution": {
      "type": "string",
      "minLength": 1
    },
    "source_record_url": {
      "type": "string",
      "format": "uri"
    },
    "source_license": {
      "type": "string",
      "minLength": 1
    },
    "source_license_url": {
      "type": "string",
      "format": "uri"
    },
    "operations": {
      "$ref": "#/$defs/stringArray"
    },
    "malware": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "$ref": "#/$defs/malwareEntry"
          }
        ]
      }
    },
    "ttps": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "$ref": "#/$defs/ttpEntry"
          }
        ]
      }
    },
    "software": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/softwareEntry"
      }
    },
    "cisa_kev_cves": {
      "$ref": "#/$defs/stringArray"
    },
    "urls": {
      "$ref": "#/$defs/stringArray"
    },
    "domains": {
      "$ref": "#/$defs/stringArray"
    },
    "ips": {
      "$ref": "#/$defs/stringArray"
    },
    "hashes": {
      "$ref": "#/$defs/stringArray"
    },
    "iocs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ips": {
          "$ref": "#/$defs/stringArray"
        },
        "domains": {
          "$ref": "#/$defs/stringArray"
        },
        "urls": {
          "$ref": "#/$defs/stringArray"
        },
        "emails": {
          "$ref": "#/$defs/stringArray"
        },
        "cves": {
          "$ref": "#/$defs/stringArray"
        },
        "md5": {
          "$ref": "#/$defs/stringArray"
        },
        "sha1": {
          "$ref": "#/$defs/stringArray"
        },
        "sha256": {
          "$ref": "#/$defs/stringArray"
        },
        "attack_techniques": {
          "$ref": "#/$defs/stringArray"
        },
        "md5_hashes": {
          "$ref": "#/$defs/stringArray"
        },
        "sha256_hashes": {
          "$ref": "#/$defs/stringArray"
        },
        "sha1_hashes": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "campaigns": {
      "type": "array"
    },
    "provenance": {
      "type": "object"
    },
    "analyst_notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "malwareEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ttpEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "technique_id": {
          "type": "string",
          "pattern": "^T\\d{4}(\\.\\d{3})?$"
        },
        "technique_name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "description": {
          "type": "string"
        },
        "stix_id": {
          "type": "string"
        }
      }
    },
    "softwareEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "mitre_id": {
          "type": "string",
          "pattern": "^S\\d{4}$"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "stix_id": {
          "type": "string"
        }
      }
    }
  }
}
